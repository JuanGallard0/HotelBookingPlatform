{
  "ConnectionStrings": {
    "HotelBookingPlatformDb": "Server=(localdb)\\mssqllocaldb;Database=HotelBookingPlatformDb;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Issuer": "HotelBookingPlatform.Api",
    "Audience": "HotelBookingPlatform.Frontend",
    "SigningKey": "super-secret-development-key-change-this-in-production-12345",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "BookingExpiration": {
    "Enabled": true,
    "CronExpression": "*/5 * * * *",
    "BatchSize": 100,
    "CancellationReason": "Expired automatically because the check-in date has passed."
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Hangfire": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  }
}
