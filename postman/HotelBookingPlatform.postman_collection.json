      "name": "Auth",
      "item": [
        {
          "name": "Register Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json?.data?.accessToken) pm.environment.set('accessToken', json.data.accessToken);",
                  "  if (json?.data?.refreshToken) pm.environment.set('refreshToken', json.data.refreshToken);",
                  "  if (json?.data?.user?.email) pm.environment.set('userEmail', json.data.user.email);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{registerEmail}}\",\n  \"firstName\": \"Postman\",\n  \"lastName\": \"Customer\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "register"
              ]
            },
            "description": "Registers a customer account and stores access/refresh tokens in the environment."
          }
        },
